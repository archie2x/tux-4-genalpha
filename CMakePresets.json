{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/_build/${hostSystemName}/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "${presetName}",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        { "name": "Debug",          "inherits": "base" },
        { "name": "Release",        "inherits": "base" },
        { "name": "RelWithDebInfo", "inherits": "base" },
        {
            "name": "Windows",
            "displayName": "Cross-compile to Windows x86_64 (mingw-w64)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/_build/Windows/Release",
            "toolchainFile": "${sourceDir}/cmake/toolchain/MinGW-Win64.cmake",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        }
    ],
    "buildPresets": [
        { "name": "Debug",          "configurePreset": "Debug" },
        { "name": "Release",        "configurePreset": "Release" },
        { "name": "RelWithDebInfo", "configurePreset": "RelWithDebInfo" },
        { "name": "Windows",        "configurePreset": "Windows" }
    ]
}
