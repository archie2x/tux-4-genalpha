---
# Conservative C-focused checks. Skip C++-only and aggressive modernize.
Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-switch-missing-default-case,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-suspicious-missing-comma,
  cert-*,
  -cert-err33-c,
  -cert-msc30-c,
  -cert-msc50-cpp,
  clang-analyzer-*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  misc-*,
  -misc-include-cleaner,
  -misc-no-recursion,
  -misc-use-internal-linkage,
  -misc-predictable-rand,
  performance-*,
  portability-*,
  readability-misleading-indentation,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  readability-redundant-declaration,
  -readability-avoid-yoda-conditions

WarningsAsErrors: ''

# Don't lint vendored / third-party code under cmake-modules, linebreak/,
# tests/CUnit/, etc. Only files under src/ that aren't vendored.
HeaderFilterRegex: '^(?!.*(linebreak|tests/CUnit|cmake-modules)/).*\.h$'

FormatStyle: file
