# Format: clang-format >=14
Language: Cpp
BasedOnStyle: LLVM
UseTab: Never
IndentWidth: 4
TabWidth: 4
BreakBeforeBraces: Allman
ColumnLimit: 80
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: true
AllowShortIfStatementsOnASingleLine: false
AllowShortFunctionsOnASingleLine: None
AllowShortLoopsOnASingleLine: false
SortIncludes: false      # SDL3/local include order is intentional
PointerAlignment: Left   # SDL_Surface* s   (matches existing)
InsertBraces: true       # always brace if/while/for/else bodies
PPIndentWidth: 1
IndentPPDirectives: AfterHash   # `#` flush-left, nested directive indented
